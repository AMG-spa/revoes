# Copia questo file in `.env` e compila i valori. `.env` è gitignored.

# Resend — invio email delle richieste. Crea l'account su https://resend.com
# e copia una API key da "API Keys".
RESEND_API_KEY=re_xxx

# Casella che riceve le richieste.
ORDER_EMAIL_TO=amg.sitiweb@gmail.com

# Mittente. In test puoi usare onboarding@resend.dev (nessun dominio da verificare).
ORDER_EMAIL_FROM=onboarding@resend.dev

# Stripe — pagamento integrato nel form (Payment Element).
# Chiave segreta (server): NO prefisso PUBLIC_ -> non finisce nel browser.
STRIPE_SECRET_KEY=sk_test_xxx
# Chiave pubblicabile (browser): prefisso PUBLIC_ -> esposta lato client.
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
