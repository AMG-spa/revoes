# Stripe — copy this file to `.env` and fill in your TEST keys.
# `.env` is gitignored; never commit real keys.

# Secret key (server only). NO "PUBLIC_" prefix -> never sent to the browser.
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret. From `stripe listen` locally, or the Dashboard in prod.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Publishable key. "PUBLIC_" prefix -> safe to expose in the browser.
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Resend — sends the order email after a confirmed payment.
RESEND_API_KEY=re_xxx
# Where the order email is delivered (the office inbox).
ORDER_EMAIL_TO=amg.sitiweb@gmail.com
# Verified sender. In test you can use Resend's onboarding@resend.dev.
ORDER_EMAIL_FROM=onboarding@resend.dev

# Vercel Blob — temporary storage for uploaded files (auto-deleted after email).
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
