---
import { menuItems } from "../data/navigation";
---

<nav class="menu-overlay" id="site-menu" aria-hidden="true">
  <button class="menu-close" type="button" aria-label="Cerrar menú" data-menu-close>
    <span></span>
    <span></span>
  </button>

  <div class="menu-extras">
    <a class="cart-menu-link" href="/carrito">
      <svg width="0.85em" height="0.85em" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4 5h2l2.2 10.2a2 2 0 0 0 2 1.6h7.4a2 2 0 0 0 1.9-1.4L21 9H7.1M10 21a1 1 0 1 0 0-2 1 1 0 0 0 0 2Zm8 0a1 1 0 1 0 0-2 1 1 0 0 0 0 2Z"/>
      </svg>
      <span class="menu-cart-count" hidden></span>
    </a>
    <a href="https://ricambi.revosrl.it/">REPUESTOS</a>
  </div>

  <div class="menu-links">
    {menuItems.map((item) => (
      <a href={item.href}>{item.label}</a>
    ))}
  </div>
</nav>

<script>
  const openButton = document.querySelector("[data-menu-open]");
  const closeButton = document.querySelector("[data-menu-close]");
  const menu = document.querySelector("#site-menu");
  const links = document.querySelectorAll(".menu-links a, .menu-extras a");

  function openMenu() {
    menu?.classList.add("is-open");
    menu?.setAttribute("aria-hidden", "false");
    document.body.classList.add("menu-is-open");
  }

  function closeMenu() {
    menu?.classList.remove("is-open");
    menu?.setAttribute("aria-hidden", "true");
    document.body.classList.remove("menu-is-open");
  }

  function updateCartCount() {
    const badge = document.querySelector<HTMLElement>(".menu-cart-count");
    if (!badge) return;
    try {
      const count = JSON.parse(localStorage.getItem("revo-cart") || "[]").length;
      badge.textContent = String(count);
      badge.hidden = count === 0;
    } catch {}
  }

  openButton?.addEventListener("click", openMenu);
  closeButton?.addEventListener("click", closeMenu);
  links.forEach((link) => link.addEventListener("click", closeMenu));

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closeMenu();
  });

  updateCartCount();
  window.addEventListener("cart:updated", updateCartCount);
</script>

<style>
  .menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    background: var(--color-orange);
    opacity: 0;
    visibility: hidden;
    clip-path: circle(0% at calc(100% - 86px) 52px);
    transition:
      clip-path 720ms cubic-bezier(0.76, 0, 0.24, 1),
      opacity 220ms ease,
      visibility 220ms ease;
  }

  .menu-overlay.is-open {
    opacity: 1;
    visibility: visible;
    clip-path: circle(150% at calc(100% - 86px) 52px);
  }

  .menu-close {
    position: absolute;
    top: clamp(28px, 4vw, 50px);
    right: clamp(24px, 5vw, 80px);
    width: 86px;
    height: 86px;
    border: 0;
    background: transparent;
    cursor: pointer;
    opacity: 0;
    transform: rotate(-90deg) scale(0.75);
    transition: opacity 480ms ease 260ms, transform 480ms ease 260ms;
  }

  .menu-overlay.is-open .menu-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  .menu-close span {
    position: absolute;
    left: 10px;
    top: 42px;
    width: 70px;
    height: 2px;
    background: #fff;
  }

  .menu-close span:first-child {
    transform: rotate(45deg);
  }

  .menu-close span:last-child {
    transform: rotate(-45deg);
  }

  .menu-links {
    display: grid;
    gap: clamp(42px, 6vh, 72px);
    width: 100%;
    padding: 0 clamp(28px, 5vw, 80px) 0 clamp(32px, 9.8vw, 170px);
  }

  .menu-links a {
    position: relative;
    width: fit-content;
    max-width: 100%;
    color: #fff;
    font-size: clamp(42px,6vw, 112px);
    line-height: 0.92;
    font-weight: 900;
    text-decoration: none;
    opacity: 0;
    transform: translateY(34px);
    transition: transform 260ms ease, text-shadow 260ms ease;
  }

  .menu-overlay.is-open .menu-links a {
    animation: menuItemIn 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .menu-links a:nth-child(1) { animation-delay: 180ms; }
  .menu-links a:nth-child(2) { animation-delay: 270ms; }
  .menu-links a:nth-child(3) { animation-delay: 360ms; }
  .menu-links a:nth-child(4) { animation-delay: 450ms; }

  .menu-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 4px;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms ease;
  }

  .menu-links a:hover {
    transform: translateX(18px);
    text-shadow: 0 10px 22px rgba(0, 0, 0, 0.16);
  }

  .menu-links a:hover::after {
    transform: scaleX(1);
  }

  @keyframes menuItemIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Mobile extras (Carrito + RICAMBI) ── */
  .menu-extras {
    display: none;
    flex-direction: column;
    gap: clamp(42px, 6vh, 72px);
    width: 100%;
    padding: 0 clamp(28px, 5vw, 80px) 0 clamp(32px, 9.8vw, 170px);
    margin-bottom: clamp(42px, 6vh, 72px);
  }

  .menu-extras a {
    position: relative;
    width: fit-content;
    color: #fff;
    font-size: clamp(42px, 7.1vw, 112px);
    line-height: 0.92;
    font-weight: 900;
    text-decoration: none;
    opacity: 0;
    transform: translateY(34px);
    transition: transform 260ms ease, text-shadow 260ms ease;
  }

  .menu-overlay.is-open .menu-extras a {
    animation: menuItemIn 720ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .menu-extras a:nth-child(1) { animation-delay: 180ms; }
  .menu-extras a:nth-child(2) { animation-delay: 270ms; }

  .menu-extras a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -8px;
    width: 100%;
    height: 4px;
    background: #fff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 240ms ease;
  }

  .menu-extras a:hover {
    transform: translateX(18px);
    text-shadow: 0 10px 22px rgba(0, 0, 0, 0.16);
  }

  .menu-extras a:hover::after {
    transform: scaleX(1);
  }

  .cart-menu-link {
    display: inline-flex !important;
    align-items: center;
    gap: 0.18em;
  }

  .menu-cart-count {
    font-size: 0.55em;
    font-weight: 900;
    line-height: 1;
    margin-top: 0.1em;
  }

  @media (max-width: 768px) {
    .menu-overlay {
      flex-direction: column;
      justify-content: center;
      overflow-y: auto;
      padding: clamp(80px, 12vh, 120px) 0;
    }

    .menu-extras {
      display: flex;
    }
  }
</style>