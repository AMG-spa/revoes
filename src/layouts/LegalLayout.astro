---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title, updated } = Astro.props;
---

<BaseLayout title={`${title} - REVO`}>
  <Header />

  <main class="legal-page">
    <article class="legal-shell">
      <a class="back-link" href="/">← Volver</a>
      <h1>{title}</h1>
      {updated && <p class="legal-updated">Última actualización: {updated}</p>}
      <div class="legal-content">
        <slot />
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style>
  .legal-page {
    min-height: 100vh;
    padding: 130px clamp(24px, 4vw, 56px) 70px;
    background: #f7f7f7;
  }

  .legal-shell {
    max-width: 820px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 48px);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.1);
  }

  .back-link {
    color: var(--color-orange);
    font-weight: 800;
    text-decoration: none;
  }

  h1 {
    margin: 22px 0 6px;
    font-size: clamp(30px, 4vw, 44px);
    font-weight: 900;
    line-height: 1.1;
  }

  .legal-updated {
    margin: 0 0 26px;
    color: #888;
    font-size: 14px;
  }

  .legal-content :global(h2) {
    margin: 32px 0 12px;
    font-size: 22px;
    font-weight: 900;
  }

  .legal-content :global(h3) {
    margin: 22px 0 8px;
    font-size: 17px;
    font-weight: 800;
  }

  .legal-content :global(p),
  .legal-content :global(li) {
    line-height: 1.6;
    color: #333;
    font-size: 15px;
  }

  .legal-content :global(ul) {
    padding-left: 20px;
    margin: 10px 0;
  }

  .legal-content :global(a) {
    color: var(--color-orange);
  }

  /* Segnaposto: dati aziendali da completare (evidenziati in giallo) */
  .legal-content :global(.ph) {
    background: #fff3cd;
    padding: 0 5px;
    border-radius: 3px;
    font-weight: 700;
  }
</style>
