---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { serviceCatalog } from "../data/serviceCatalog";
---

<BaseLayout title="Carrito - REVO">
  <Header />

  <main class="cart-page">
    <section class="cart-shell">
      <h1>Carrito</h1>
      <a class="back-link" href="https://revoes.vercel.app/#servicios">← Volver</a>
      <div class="cart-items" data-cart-items></div>

      <aside class="cart-summary">
        <p>Subtotal: <strong data-subtotal>0,00 €</strong></p>
        <p>IVA 22%: <strong data-vat>0,00 €</strong></p>
        <p class="total">Total: <strong data-total>0,00 €</strong></p>

        <a class="checkout-button" href="/checkout" data-checkout>Continuar al checkout</a>
      </aside>

      <section class="add-services">
        <h2>Añadir un servicio</h2>
        <div class="service-cards">
          {serviceCatalog.map((s) => (
            <a class="service-card" href={`/servicios/${s.slug}`}>
              <span class="service-card-title">{s.title}</span>
              <span class="service-card-price">
                {s.price > 0
                  ? s.price.toLocaleString("es-ES", { style: "currency", currency: "EUR" }) + " + IVA"
                  : "Solicitar"}
              </span>
              <span class="service-card-cta">{s.ctaLabel} →</span>
            </a>
          ))}
        </div>
      </section>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  import { getCart, removeCartItem } from "../lib/cart";

  const VAT_RATE = 0.22;

  const itemsContainer = document.querySelector<HTMLElement>("[data-cart-items]")!;
  const subtotalEl = document.querySelector<HTMLElement>("[data-subtotal]")!;
  const vatEl = document.querySelector<HTMLElement>("[data-vat]")!;
  const totalEl = document.querySelector<HTMLElement>("[data-total]")!;
  const checkout = document.querySelector<HTMLElement>("[data-checkout]")!;

  const currency = new Intl.NumberFormat("es-ES", {
    style: "currency",
    currency: "EUR",
  });

  function renderCart() {
    const items = getCart();

    if (!items.length) {
      itemsContainer.innerHTML = `<p class="empty-cart">Tu carrito está vacío.</p>`;
      checkout.classList.add("is-disabled");
    } else {
      checkout.classList.remove("is-disabled");

      itemsContainer.innerHTML = items
        .map((item) => {
          const price = Number(item.price || 0);

          return `
            <article class="cart-item">
              <h2>${item.title}</h2>
              <div class="cart-item-footer">
                <p>${currency.format(price)} + IVA</p>
                <button class="remove-btn" type="button" data-remove="${item.id}" aria-label="Eliminar">×</button>
              </div>
            </article>
          `;
        })
        .join("");
    }

    const subtotal = items.reduce((sum, item) => sum + Number(item.price || 0), 0);
    const vat = subtotal * VAT_RATE;
    const total = subtotal + vat;

    subtotalEl.textContent = currency.format(subtotal);
    vatEl.textContent = currency.format(vat);
    totalEl.textContent = currency.format(total);
  }

  itemsContainer.addEventListener("click", (event) => {
    const button = (event.target as HTMLElement).closest<HTMLElement>("[data-remove]");
    if (!button) return;

    removeCartItem(button.dataset.remove!);
    renderCart();
  });

  renderCart();
</script>

<style>
    .back-link {
    color: var(--color-orange);
    font-weight: 800;
    text-decoration: none;
  }

  .cart-page {
    min-height: 100vh;
    padding: 130px clamp(24px, 4vw, 56px) 70px;
    background: #f7f7f7;
  }

  .cart-shell {
    max-width: 980px;
    margin: 0 auto;
  }

  h1 {
    margin: 0 0 28px;
    font-size: clamp(42px, 5vw, 64px);
  }

  /* ── Cart items ── */
  .cart-items {
    display: grid;
    gap: 16px;
    margin-top: 10px;
  }

  :global(.cart-item),
  .cart-summary {
    border-radius: 8px;
    background: #fff;
    padding: 22px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  :global(.cart-item) {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  :global(.cart-item h2) {
    margin: 0;
    font-size: 18px;
  }

  :global(.cart-item-footer) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  :global(.cart-item-footer p) {
    margin: 0;
    color: #555;
    font-size: 15px;
  }

  :global(.remove-btn) {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border: none;
    border-radius: 50%;
    background: var(--color-orange);
    color: #fff;
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    transition: opacity 180ms ease;
  }

  :global(.remove-btn:hover) {
    opacity: 0.8;
  }

  /* ── Summary ── */
  .cart-summary {
    margin-top: 22px;
  }

  .cart-summary p {
    display: flex;
    justify-content: space-between;
    margin: 12px 0;
    font-size: 20px;
  }

  .cart-summary .total {
    font-size: 26px;
    font-weight: 900;
  }

  .checkout-button {
    display: flex;
    min-height: 54px;
    margin-top: 22px;
    align-items: center;
    justify-content: center;
    border-radius: 5px;
    color: #fff;
    background: var(--color-orange);
    font-size: 20px;
    font-weight: 900;
    text-decoration: none;
    transition: opacity 180ms ease;
  }

  .checkout-button.is-disabled {
    pointer-events: none;
    opacity: 0.45;
  }

  /* ── Add services ── */
  .add-services {
    margin-top: 48px;
  }

  .add-services h2 {
    margin: 0 0 20px;
    font-size: clamp(22px, 2.5vw, 30px);
    font-weight: 900;
    color: var(--color-black);
  }

  .service-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .service-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 22px;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    text-decoration: none;
    color: inherit;
    border: 2px solid transparent;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }

  .service-card:hover {
    border-color: var(--color-orange);
    box-shadow: 0 12px 30px rgba(239, 70, 29, 0.12);
  }

  .service-card-title {
    font-size: 15px;
    font-weight: 900;
    line-height: 1.2;
  }

  .service-card-price {
    font-size: 13px;
    color: #666;
  }

  .service-card-cta {
    margin-top: auto;
    font-size: 13px;
    font-weight: 800;
    color: var(--color-orange);
  }

  @media (max-width: 700px) {
    .service-cards {
      grid-template-columns: 1fr;
    }
  }
</style>