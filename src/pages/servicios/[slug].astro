---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { serviceCatalog } from "../../data/serviceCatalog";

export function getStaticPaths() {
  return serviceCatalog.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Solo i servizi "cart" richiedono il pagamento integrato (Payment Element).
const isPaid = service.paymentType === "cart";
---

<BaseLayout title={`${service.title} - REVO`}>
  <Header />

  <main class="service-page">
    <section class="form-shell">
      <a class="back-link" href="/">← Volver</a>
      <div class="form-heading">
        <p>Servicio REVO</p>
        <h1>{service.title}</h1>

        {service.paymentType === "cart" && (
          <strong>
            {service.price.toLocaleString("es-ES", {
              style: "currency",
              currency: "EUR",
            })} (IVA incluida)
          </strong>
        )}
      </div>

      <form
        class="service-form"
        data-service-form
        data-paid={isPaid ? "true" : undefined}
        data-price={service.price}
        data-title={service.title}
        enctype="multipart/form-data"
      >
        <input type="hidden" name="slug" value={service.slug} />

        {service.fields.map((field) => (
          <label class="field">
                     <span>
              {field.label}
              {field.required && <em>*</em>}
              {field.hint && (
                <span class="info-icon" tabindex="0">
                  ⓘ
                  <span class="info-tooltip">
                    {field.hint}
                    {field.hintImage && <img src={field.hintImage} alt="Ejemplo" loading="lazy" />}
                  </span>
                </span>
              )}
            </span>

            {field.type === "choice" ? (
              <div class="choice-cards">
                {field.options?.map((opt) => (
                  <label class="choice-card">
                    <input type="radio" name={field.name} value={opt.value} required={field.required} />
                    <span class="choice-card-title">{opt.label}</span>
                    <span class="choice-card-price">
                      {opt.price.toLocaleString("es-ES", { style: "currency", currency: "EUR" })}
                      <em> + IVA + DEPLACIAMENTO </em>
                    </span>
                  </label>
                ))}
              </div>
            ) : field.type === "textarea" ? (
              <textarea name={field.name} required={field.required}></textarea>
            ) : (
              <input
                name={field.name}
                type={field.type}
                required={field.required}
                accept={field.type === "file" ? "image/*,.pdf" : undefined}
                data-label={field.type === "file" ? field.label : undefined}
              />
            )}
          </label>
        ))}

        {isPaid && (
          <div class="payment-block">
            <span class="payment-label">Pago con tarjeta</span>
            <div id="payment-element"></div>
          </div>
        )}

        <button class="submit-button" type="submit">{service.ctaLabel}</button>
        <p class="form-note" data-note role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <script>
    import { loadStripe, type Stripe, type StripeElements } from "@stripe/stripe-js";

    const form = document.querySelector<HTMLFormElement>("[data-service-form]")!;
    const note = document.querySelector<HTMLElement>("[data-note]")!;
    const button = form.querySelector<HTMLButtonElement>('button[type="submit"]')!;
    const isPaid = form.dataset.paid === "true";
    const slug = (form.querySelector('input[name="slug"]') as HTMLInputElement).value;
    const ctaLabel = button.textContent ?? "Enviar";
    const servicePrice = Number(form.dataset.price ?? 0);
    const serviceTitle = form.dataset.title ?? slug;

    let stripe: Stripe | null = null;
    let elements: StripeElements | null = null;
    let paymentIntentId: string | null = null;

    // Eventi GA4 (funnel begin_checkout -> purchase). Rispetta il consenso
    // cookie: se l'utente non ha accettato le analitiche, non registra nulla.
    function trackEvent(name: string, params: Record<string, unknown> = {}) {
      if (localStorage.getItem("revo-cookie-consent") !== "granted") return;
      (window as any).dataLayer = (window as any).dataLayer || [];
      (window as any).dataLayer.push(["event", name, params]);
    }

    function setNote(text: string, kind: "error" | "success") {
      note.textContent = text;
      note.classList.remove("is-error", "is-success");
      note.classList.add(kind === "error" ? "is-error" : "is-success");
    }

    function resetButton() {
      button.disabled = false;
      button.textContent = ctaLabel;
    }

    // Per i servizi a pagamento: prepara il Payment Element al caricamento.
    if (isPaid) {
      initPayment();
    }

    async function initPayment() {
      try {
        stripe = await loadStripe(import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY);
        if (!stripe) throw new Error("Stripe no disponible");

        const res = await fetch("/api/create-payment-intent", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ slug }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "No se pudo iniciar el pago.");

        paymentIntentId = String(data.clientSecret).split("_secret")[0];
        elements = stripe.elements({ clientSecret: data.clientSecret });
        elements.create("payment").mount("#payment-element");

        trackEvent("begin_checkout", {
          currency: "EUR",
          value: servicePrice,
          items: [{ item_name: serviceTitle, item_id: slug, price: servicePrice }],
        });
      } catch (err) {
        setNote(err instanceof Error ? err.message : "Error al iniciar el pago.", "error");
        button.disabled = true;
      }
    }

    // Ridimensiona/comprime le immagini così il totale resta sotto il limite
    // di Vercel (4,5 MB per richiesta). I PDF e gli altri file restano invariati.
    async function compressImage(file: File): Promise<File> {
      if (!file.type.startsWith("image/")) return file;
      try {
        const bitmap = await createImageBitmap(file);
        const maxDim = 1600;
        let { width, height } = bitmap;
        if (width > maxDim || height > maxDim) {
          const scale = maxDim / Math.max(width, height);
          width = Math.round(width * scale);
          height = Math.round(height * scale);
        }
        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        canvas.getContext("2d")!.drawImage(bitmap, 0, 0, width, height);
        const blob = await new Promise<Blob | null>((res) =>
          canvas.toBlob(res, "image/jpeg", 0.8)
        );
        if (!blob) return file;
        return new File([blob], file.name.replace(/\.\w+$/, ".jpg"), { type: "image/jpeg" });
      } catch {
        return file; // in caso di problemi, invia l'originale
      }
    }

    // I PDF (e altri documenti non-immagine) non vengono compressi: se troppo
    // pesanti da soli possono far superare il limite di 4,5 MB di Vercel.
    const MAX_DOCUMENT_BYTES = 8 * 1024 * 1024; // 8 MB

    function findOversizedDocument(): string | null {
      const fileInputs = form.querySelectorAll<HTMLInputElement>('input[type="file"]');
      for (const input of fileInputs) {
        const file = input.files?.[0];
        if (!file || file.size === 0) continue;
        if (file.type.startsWith("image/")) continue; // le foto vengono comunque compresse dopo
        if (file.size > MAX_DOCUMENT_BYTES) {
          return input.dataset.label || "archivo";
        }
      }
      return null;
    }

    async function buildPayload(): Promise<FormData> {
      const fd = new FormData(form);
      const fileInputs = form.querySelectorAll<HTMLInputElement>('input[type="file"]');
      for (const input of fileInputs) {
        const file = input.files?.[0];
        if (file && file.size > 0) {
          const out = await compressImage(file);
          fd.set(input.name, out, out.name);
        }
      }
      return fd;
    }

    async function sendOrder(paid: boolean) {
      button.textContent = "Preparando archivos…";
      const payload = await buildPayload();
      button.textContent = "Enviando datos…";
      const res = await fetch("/api/send-order", { method: "POST", body: payload });
      const data = await res.json().catch(() => ({}));

      if (paid) {
        // Il pagamento è già riuscito: in ogni caso porta il cliente alla
        // pagina di ringraziamento (anche se l'invio dati avesse un intoppo).
        window.location.href = "/pedido-confirmado";
        return;
      }

      if (!res.ok) {
        throw new Error(data.error || "No se pudo enviar la solicitud.");
      }

      form.reset();
      setNote("¡Solicitud enviada! Te contactaremos lo antes posible.", "success");
      button.textContent = ctaLabel;
      button.disabled = false;
    }

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      // Validazione nativa: evidenzia il primo campo mancante/errato.
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      const oversizedLabel = findOversizedDocument();
      if (oversizedLabel) {
        setNote(
          `El archivo "${oversizedLabel}" pesa demasiado (máx. 8 MB). Comprímelo o envíalo por email a revoesp@revosrl.com.`,
          "error"
        );
        return;
      }

      note.textContent = "";
      note.classList.remove("is-error", "is-success");
      button.disabled = true;

      try {
        if (isPaid) {
          if (!stripe || !elements) throw new Error("El pago no está listo. Recarga la página.");

          button.textContent = "Procesando pago…";

          // Associa l'email del cliente al pagamento -> Stripe gli invia la ricevuta.
          const emailInput = form.querySelector('input[name="email"]') as HTMLInputElement | null;
          if (paymentIntentId && emailInput?.value) {
            await fetch("/api/attach-receipt-email", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ paymentIntentId, email: emailInput.value }),
            }).catch(() => {}); // non bloccare il pagamento se fallisce
          }

          // Prima il pagamento; la mail parte SOLO se va a buon fine.
          const { error, paymentIntent } = await stripe.confirmPayment({
            elements,
            redirect: "if_required",
          });

          if (error) {
            setNote(error.message || "El pago no se pudo completar.", "error");
            resetButton();
            return;
          }
          if (paymentIntent?.status !== "succeeded") {
            setNote("El pago no se completó. Inténtalo de nuevo.", "error");
            resetButton();
            return;
          }

          trackEvent("purchase", {
            transaction_id: paymentIntentId,
            currency: "EUR",
            value: servicePrice,
            items: [{ item_name: serviceTitle, item_id: slug, price: servicePrice }],
          });

          await sendOrder(true);
        } else {
          await sendOrder(false);
        }
      } catch (err) {
        setNote(err instanceof Error ? err.message : "Error al enviar la solicitud.", "error");
        resetButton();
      }
    });
  </script>

  <Footer />
</BaseLayout>

<style>
  .service-page {
    min-height: 100vh;
    padding: 130px clamp(24px, 4vw, 56px) 70px;
    background: #f7f7f7;
  }

  .form-shell {
    max-width: 980px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 46px);
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
  }

  .back-link {
    color: var(--color-orange);
    font-weight: 800;
    text-decoration: none;
  }

  .form-heading {
    margin: 28px 0 30px;
  }

  .form-heading p {
    margin: 0 0 8px;
    color: var(--color-orange);
    font-weight: 900;
  }

  .form-heading h1 {
    margin: 0;
    font-size: clamp(36px, 5vw, 58px);
    line-height: 1;
  }

  .form-heading strong {
    display: block;
    margin-top: 16px;
    font-size: 24px;
  }

  .service-form {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .field {
    display: grid;
    gap: 8px;
    font-weight: 800;
  }

  .field span em {
    color: var(--color-orange);
    font-style: normal;
  }

    .info-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    margin-left: 6px;
    border-radius: 50%;
    background: #e2e2e2;
    color: #555;
    font-size: 12px;
    font-weight: 700;
    cursor: help;
    vertical-align: middle;
  }

  .info-tooltip {
    display: none;
    position: absolute;
    bottom: calc(100% + 8px);
    left: 0;
    z-index: 10;
    width: 220px;
    padding: 10px 12px;
    border-radius: 6px;
    background: #1a1a1a;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    line-height: 1.4;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .info-tooltip img {
    display: block;
    width: 100%;
    margin-top: 8px;
    border-radius: 4px;
  }

  .info-icon:hover .info-tooltip,
  .info-icon:focus .info-tooltip {
    display: block;
  }

  input,
  textarea {
    width: 100%;
    min-height: 48px;
    border: 1px solid #cfcfcf;
    border-radius: 5px;
    padding: 10px 12px;
    font: inherit;
  }

  textarea {
    min-height: 130px;
    resize: vertical;
  }

  .field:has(textarea),
  .field:has(input[type="file"]),
  .field:has(.choice-cards) {
    grid-column: 1 / -1;
  }

  .choice-cards {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .choice-card {
    flex: 1 1 200px;
    display: grid;
    gap: 6px;
    padding: 16px;
    border: 2px solid #cfcfcf;
    border-radius: 8px;
    cursor: pointer;
    font-weight: 800;
  }

  .choice-card input[type="radio"] {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .choice-card:has(input:checked) {
    border-color: var(--color-orange);
    background: #fff7f0;
  }

  .choice-card:has(input:focus-visible) {
    outline: 2px solid var(--color-orange);
    outline-offset: 2px;
  }

  .choice-card-title {
    font-size: 16px;
  }

  .choice-card-price {
    font-weight: 600;
    color: #555;
    font-size: 14px;
  }

  .choice-card-price em {
    font-style: normal;
    font-size: 12px;
  }

  .submit-button {
    grid-column: 1 / -1;
    min-height: 54px;
    border: 0;
    border-radius: 5px;
    color: #fff;
    background: var(--color-orange);
    font-size: 20px;
    font-weight: 900;
    cursor: pointer;
  }

  .payment-block {
    grid-column: 1 / -1;
    display: grid;
    gap: 10px;
    padding: 18px;
    border: 1px solid #e2e2e2;
    border-radius: 8px;
    background: #fafafa;
  }

  .payment-label {
    font-weight: 800;
  }

  .form-note {
    grid-column: 1 / -1;
    margin: 4px 0 0;
    font-weight: 800;
  }

  .form-note:empty {
    display: none;
  }

  .form-note.is-error {
    color: #c0261b;
  }

  .form-note.is-success {
    color: #1b8a3a;
  }

  @media (max-width: 760px) {
    .service-form {
      grid-template-columns: 1fr;
    }
  }
</style>